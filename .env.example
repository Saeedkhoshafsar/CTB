# CTB server configuration — copy to .env and adjust.

# REQUIRED — master secret for encryption-at-rest + session signing (min 16 chars).
# Generate: openssl rand -hex 24
CTB_SECRET=

# Admin panel credentials (login is disabled with 503 until CTB_ADMIN_PASS is set).
CTB_ADMIN_USER=admin
CTB_ADMIN_PASS=

# Operator ("manager") login — sees ONLY the Collections Data section
# (records/files), never bots/flows/executions. Disabled until
# CTB_OPERATOR_PASS is set. (P3.5-T2, ARCHITECTURE §13.5)
CTB_OPERATOR_USER=operator
# CTB_OPERATOR_PASS=

# Bootstrap-owner Telegram user id (K-T2). On FIRST bring-up (empty panel_admins
# table) a successful admin login mints the singleton OWNER row keyed by this
# Telegram id — binding the panel to a real Telegram identity (owner > admin >
# operator; the owner can never be removed and only the owner can transfer
# ownership). Optional: unset ⇒ the legacy env-only admin login still works.
# Find your id with @userinfobot in Telegram.
# CTB_OWNER_TG_ID=123456789

# SQLite database file (created + migrated automatically on boot).
CTB_DB_PATH=data/ctb.sqlite

# Local directory for uploaded Collection files (image/file fields → ${CTB_DATA_DIR}/files).
CTB_DATA_DIR=data

# HTTP listener
CTB_PORT=3000
CTB_HOST=0.0.0.0

# Public base URL — required only for webhook-mode bots (polling needs nothing).
# CTB_PUBLIC_URL=https://bot.example.com

# Code node $http allow-list (comma-separated hosts; ".example.com" = any
# subdomain). Empty/unset = unrestricted (single-admin default).
# CTB_CODE_HTTP_ALLOWLIST=api.example.com,.webhook.site

# development | test | production
NODE_ENV=development
