{
  "nodes": [
    {
      "id": "trigger",
      "type": "tg.trigger",
      "params": { "event": "command", "command": "/start" },
      "position": { "x": 0, "y": 0 }
    },
    {
      "id": "ask_name",
      "type": "tg.waitForReply",
      "params": {
        "prompt": { "text": "سلام! اسمت چیه؟" },
        "expect": "text",
        "save_to": "name",
        "timeout": "1d"
      },
      "position": { "x": 240, "y": 0 }
    },
    {
      "id": "ask_age",
      "type": "tg.waitForReply",
      "params": {
        "prompt": { "text": "چند سالته {{ $vars.name }}؟" },
        "expect": "number",
        "validation": { "min": 1, "max": 120 },
        "invalid_message": "یه عدد بین ۱ تا ۱۲۰ بفرست",
        "max_retries": 2,
        "save_to": "age"
      },
      "position": { "x": 480, "y": 0 }
    },
    {
      "id": "check_adult",
      "type": "flow.if",
      "params": {
        "conditions": [
          { "value1": "{{ $vars.age }}", "operator": "gte", "value2": "18" }
        ]
      },
      "position": { "x": 720, "y": 0 }
    },
    {
      "id": "greet",
      "type": "tg.sendMessage",
      "params": { "type": "text", "text": "سلام {{ $vars.name }}، {{ $vars.age }} ساله! خوش اومدی 🎉" },
      "position": { "x": 960, "y": -80 }
    },
    {
      "id": "greet_minor",
      "type": "tg.sendMessage",
      "params": { "type": "text", "text": "سلام {{ $vars.name }}! 👋" },
      "position": { "x": 960, "y": 80 }
    },
    {
      "id": "too_many_retries",
      "type": "flow.stopError",
      "params": { "message": "سن نامعتبر بعد از چند تلاش", "notify_user": false },
      "position": { "x": 480, "y": 160 },
      "note": "Reached via the invalid port of ask_age"
    }
  ],
  "edges": [
    { "id": "e1", "from": { "node": "trigger", "port": "main" }, "to": { "node": "ask_name", "port": "main" } },
    { "id": "e2", "from": { "node": "ask_name", "port": "reply" }, "to": { "node": "ask_age", "port": "main" } },
    { "id": "e3", "from": { "node": "ask_age", "port": "reply" }, "to": { "node": "check_adult", "port": "main" } },
    { "id": "e4", "from": { "node": "ask_age", "port": "invalid" }, "to": { "node": "too_many_retries", "port": "main" } },
    { "id": "e5", "from": { "node": "check_adult", "port": "true" }, "to": { "node": "greet", "port": "main" } },
    { "id": "e6", "from": { "node": "check_adult", "port": "false" }, "to": { "node": "greet_minor", "port": "main" } }
  ]
}
